# apps/server/.env

# Veritabanı
DATABASE_URL="postgresql://discordalt:discordalt123@localhost:5432/discordalt"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="en-az-32-karakter-guclu-secret-buraya-yazilacak"
JWT_REFRESH_SECRET="baska-bir-guclu-secret-buraya-yazilacak-32char"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Cloudflare R2
R2_ACCOUNT_ID="cloudflare-account-id"
R2_ACCESS_KEY_ID="r2-access-key"
R2_SECRET_ACCESS_KEY="r2-secret-key"
R2_BUCKET_NAME="comunic8-files"
R2_PUBLIC_URL="https://files.yourdomain.com"

# Uygulama
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"
